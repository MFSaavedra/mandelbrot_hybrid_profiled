# Build artifacts
*.o
mandelHybrid

# Generated frame images and video
img/
*.png
*.mkv
*.mp4

# Nsight profiling data (large binary files)
*.nsys-rep
*.sqlite
*.ncu-rep

# Archives
*.7z
*.zip

# LaTeX intermediates
*.aux
*.log
# ... but *.log above must not swallow raw experiment run records (it had been
# silently untracking exp-04's stderr/stdout, exp-06/07's quiet0/ region logs
# and exp-19's sweep.log, all documented as tracked contents in CLAUDE.md)
!experiments/**/*.log
# ffmpeg encode logs are regenerated together with the (gitignored) videos
experiments/*/viz_*/ff*.log
*.bbl
*.blg
*.toc
*.out
# ... but captured console outputs in experiments stay tracked
!experiments/**/*.out
*.fls
*.fdb_latexmk
*.synctex.gz

# Doxygen generated output (Doxyfile + docs/mainpage.dox stay tracked)
docs/html/
docs/doxygen-warnings.log

# Claude Code local settings
.claude/

# Distributed-rendering scratch: per-rank workdirs, PNG collection, and the
# identity check's ref/collect trees (results_identity.csv stays tracked)
dist_work/
experiments/25-frame-distribution/collect/
experiments/25-frame-distribution/verify_work/
experiments/25-frame-distribution/bench/

# ncu raw per-kernel dumps (regenerate via ncu --import from the .ncu-rep)
experiments/16-ncu-divergence/analysis/*_full.csv
experiments/16-ncu-divergence/analysis/*_warp.csv

experiments/17-ncu-zoom-points/analysis/*_full.csv
experiments/17-ncu-zoom-points/analysis/*_warp.csv

experiments/24-ncu-gpu-periodicity/analysis/*_full.csv
experiments/24-ncu-gpu-periodicity/analysis/*_warp.csv
